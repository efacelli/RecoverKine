# Conexion a Neon PostgreSQL
# Obtener desde el dashboard de Neon (https://console.neon.tech)
DATABASE_URL="postgresql://usuario:password@ep-xxxxx.us-east-2.aws.neon.tech/recover?sslmode=require"

# Puerto del servidor
PORT=4000

# Entorno
NODE_ENV=development

# JWT
JWT_SECRET="cambiar_por_un_secreto_largo_y_aleatorio_en_produccion"
JWT_EXPIRES_IN="8h"

# Credenciales del unico usuario del sistema (se usan solo en el seed inicial)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="cambiar_esta_password"

# CORS
FRONTEND_URL="http://localhost:5173"
